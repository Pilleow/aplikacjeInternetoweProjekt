# Prisma database connection URL — update password to match DB_PASSWORD
# Inside Docker use: postgresql://postgres:changeme@db:5432/eduflow
DATABASE_URL=postgresql://postgres:changeme@localhost:5432/eduflow

# PostgreSQL superuser password used by the db service in docker-compose
DB_PASSWORD=changeme

# MinIO root credentials used by the minio service in docker-compose
MINIO_USER=minioadmin
MINIO_PASSWORD=minioadmin

# MinIO S3-compatible API endpoint (inside Docker use http://minio:9000)
MINIO_ENDPOINT=http://localhost:9000

# MinIO access key — equals MINIO_USER for local dev
MINIO_ACCESS_KEY=minioadmin

# MinIO secret key — equals MINIO_PASSWORD for local dev
MINIO_SECRET_KEY=minioadmin

# S3 bucket name for uploaded files and generated certificates
MINIO_BUCKET=eduflow

# Redis connection URL (inside Docker use redis://redis:6379)
REDIS_URL=redis://localhost:6379

# NextAuth.js signing secret — generate with: openssl rand -base64 32
NEXTAUTH_SECRET=change-me-in-production

# Canonical public URL of the app — used by NextAuth.js for OAuth callbacks
NEXTAUTH_URL=http://localhost:3000
